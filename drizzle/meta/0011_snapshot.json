          "name": "conversions_tracking_link_id_not_blank_check",
          "value": "char_length(trim(\"conversions\".\"tracking_link_id\")) > 0"
        },
        "conversions_status_check": {
          "name": "conversions_status_check",
          "value": "\"conversions\".\"status\" in (\n        'pending',\n        'approved',\n        'rejected',\n        'payable',\n        'paid'\n      )"
        },
        "conversions_order_amount_non_negative_check": {
          "name": "conversions_order_amount_non_negative_check",
          "value": "\"conversions\".\"order_amount\" >= 0"
        },
        "conversions_network_commission_non_negative_check": {
          "name": "conversions_network_commission_non_negative_check",
          "value": "\"conversions\".\"network_commission\" >= 0"
        },
        "conversions_user_cashback_non_negative_check": {
          "name": "conversions_user_cashback_non_negative_check",
          "value": "\"conversions\".\"user_cashback\" >= 0"
        },
        "conversions_platform_profit_non_negative_check": {
          "name": "conversions_platform_profit_non_negative_check",
          "value": "\"conversions\".\"platform_profit\" >= 0"
        },
        "conversions_commission_allocation_check": {
          "name": "conversions_commission_allocation_check",
          "value": "\"conversions\".\"network_commission\" = \"conversions\".\"user_cashback\" + \"conversions\".\"platform_profit\""
        },
        "conversions_rejection_metadata_check": {
          "name": "conversions_rejection_metadata_check",
          "value": "\n        (\n          \"conversions\".\"status\" = 'rejected'\n          and \"conversions\".\"rejected_at\" is not null\n          and nullif(trim(\"conversions\".\"rejected_reason\"), '') is not null\n        )\n        or\n        (\n          \"conversions\".\"status\" <> 'rejected'\n          and \"conversions\".\"rejected_at\" is null\n          and \"conversions\".\"rejected_reason\" is null\n        )\n      "
        },
        "conversions_approved_at_check": {
          "name": "conversions_approved_at_check",
          "value": "\n        (\n          \"conversions\".\"status\" in ('approved', 'payable', 'paid')\n          and \"conversions\".\"approved_at\" is not null\n        )\n        or\n        (\n          \"conversions\".\"status\" in ('pending', 'rejected')\n          and \"conversions\".\"approved_at\" is null\n        )\n      "
        },
        "conversions_payable_at_check": {
          "name": "conversions_payable_at_check",
          "value": "\n        (\n          \"conversions\".\"status\" in ('payable', 'paid')\n          and \"conversions\".\"payable_at\" is not null\n        )\n        or\n        (\n          \"conversions\".\"status\" in ('pending', 'approved', 'rejected')\n          and \"conversions\".\"payable_at\" is null\n        )\n      "
        },
        "conversions_paid_at_check": {
          "name": "conversions_paid_at_check",
          "value": "\n        (\n          \"conversions\".\"status\" = 'paid'\n          and \"conversions\".\"paid_at\" is not null\n        )\n        or\n        (\n          \"conversions\".\"status\" <> 'paid'\n          and \"conversions\".\"paid_at\" is null\n        )\n      "
        },
        "conversions_lifecycle_timestamp_order_check": {
          "name": "conversions_lifecycle_timestamp_order_check",
          "value": "\n        (\"conversions\".\"approved_at\" is null or \"conversions\".\"approved_at\" >= \"conversions\".\"occurred_at\")\n        and\n        (\n          \"conversions\".\"payable_at\" is null\n          or (\n            \"conversions\".\"approved_at\" is not null\n            and \"conversions\".\"payable_at\" >= \"conversions\".\"approved_at\"\n          )\n        )\n        and\n        (\n          \"conversions\".\"paid_at\" is null\n          or (\n            \"conversions\".\"payable_at\" is not null\n            and \"conversions\".\"paid_at\" >= \"conversions\".\"payable_at\"\n          )\n        )\n        and\n        (\n          \"conversions\".\"rejected_at\" is null\n          or \"conversions\".\"rejected_at\" >= \"conversions\".\"occurred_at\"\n        )\n      "
        }
      },
