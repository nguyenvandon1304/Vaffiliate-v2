      "checkConstraints": {
        "conversions_network_not_blank_check": {
          "name": "conversions_network_not_blank_check",
          "value": "char_length(trim(\"conversions\".\"network\")) > 0"
        },
        "conversions_external_order_id_not_blank_check": {
